---
import IconDiscord from '../icons/IconDiscord.astro';

interface Props {
  kicker: string;
  title: string;
  buttonLabel: string;
}

const { kicker, title, buttonLabel } = Astro.props;
---

<section class="surface discord-banner section-space">
  <p class="mono">{kicker}</p>
  <h3>{title}</h3>
  <a class="button button-primary" href="https://discord.gg/RScK4jEC7" target="_blank" rel="noreferrer">
    <IconDiscord />
    {buttonLabel}
  </a>
</section>

<style>
  .discord-banner {
    padding: 1.8rem;
    display: grid;
    gap: 0.5rem;
    align-items: center;
  }

  p {
    color: var(--secondary);
    font-size: 0.84rem;
  }

  h3 {
    font-size: clamp(1.2rem, 2.4vw, 1.8rem);
  }

  .button {
    justify-self: start;
    margin-top: 0.3rem;
  }
</style>
