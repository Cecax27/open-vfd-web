---
import type { CollectionEntry } from 'astro:content';

interface Props {
  docs: CollectionEntry<'docs'>[];
  currentId?: string;
}

const { docs, currentId } = Astro.props;

const labelMap: Record<string, string> = {
  'getting-started': 'Getting Started',
  simulation: 'Simulation',
  'opc-ua': 'OPC UA',
  reference: 'Reference'
};

const categories = Object.keys(labelMap);
---

<aside class="surface sidebar">
  <p class="title mono">Documentation</p>

  {categories.map((category) => {
    const entries = docs
      .filter((entry) => entry.data.category === category)
      .sort((a, b) => a.data.order - b.data.order);

    return (
      <section>
        <h3>{labelMap[category]}</h3>
        <ul>
          {entries.map((entry) => (
            <li>
              <a
                href={`/docs/${entry.id}`}
                class:list={{ active: currentId === entry.id }}
                aria-current={currentId === entry.id ? 'page' : undefined}
              >
                {entry.data.title}
              </a>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</aside>

<style>
  .sidebar {
    padding: 1rem;
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 120px);
    overflow: auto;
  }

  .title {
    color: var(--accent-primary);
    font-size: 0.76rem;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }

  section + section {
    margin-top: 1rem;
  }

  h3 {
    font-size: 0.84rem;
    margin-bottom: 0.45rem;
    color: var(--text-secondary);
  }

  ul {
    list-style: none;
    display: grid;
    gap: 0.35rem;
  }

  a {
    display: block;
    color: var(--text-muted);
    padding: 0.35rem 0.5rem;
    border-radius: 8px;
    transition: color 0.2s ease, background-color 0.2s ease;
    font-size: 0.9rem;
  }

  a:hover {
    color: var(--text-primary);
    background: var(--accent-soft);
  }

  a.active {
    color: var(--text-primary);
    background: var(--accent-soft);
  }

  @media (max-width: 940px) {
    .sidebar {
      position: static;
      max-height: none;
    }
  }
</style>
