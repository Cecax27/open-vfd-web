---
import IconGithub from '../icons/IconGithub.astro';
import IconDiscord from '../icons/IconDiscord.astro';
import IconHeart from '../icons/IconHeart.astro';
import IconArrowRight from '../icons/IconArrowRight.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  label: string;
  badge?: string;
}

const { title, description, href, label, badge } = Astro.props;

const getIconType = (url: string): 'github' | 'discord' | 'sponsors' | 'link' => {
  if (url.includes('github.com/sponsors')) {
    return 'sponsors';
  }

  if (url.includes('discord.gg')) {
    return 'discord';
  }

  if (url.includes('github.com')) {
    return 'github';
  }

  return 'link';
};

const iconType = getIconType(href);
---

<article class="surface card">
  <div class="head">
    <h3>{title}</h3>
    {badge && <span class="badge mono">{badge}</span>}
  </div>
  <p>{description}</p>
  <a class="button button-secondary" href={href} target="_blank" rel="noreferrer">
    {iconType === 'github' && <IconGithub />}
    {iconType === 'discord' && <IconDiscord />}
    {iconType === 'sponsors' && <IconHeart />}
    {iconType === 'link' && <IconArrowRight />}
    {label}
  </a>
</article>

<style>
  .card {
    padding: 1.25rem;
    display: grid;
    gap: 0.65rem;
  }

  .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .badge {
    font-size: 0.7rem;
    color: var(--accent-primary);
    border: 1px solid rgba(0, 209, 178, 0.4);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
  }

  p {
    color: var(--text-secondary);
  }

  .button {
    justify-self: start;
  }
</style>
