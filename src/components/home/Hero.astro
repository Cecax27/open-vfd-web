---
import IconDownload from '../icons/IconDownload.astro';
import IconBook from '../icons/IconBook.astro';

interface Props {
  kicker: string;
  title: string;
  summary: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  secondaryCtaLabel: string;
  secondaryCtaHref: string;
}

const { kicker, title, summary, primaryCtaLabel, primaryCtaHref, secondaryCtaLabel, secondaryCtaHref } = Astro.props;
---

<section class="hero">
  <p class="mono hero-kicker">{kicker}</p>
  <h1>{title}</h1>
  <p class="summary">{summary}</p>
  <div class="actions">
    <a class="button button-primary" href={primaryCtaHref}>
      <IconDownload />
      {primaryCtaLabel}
    </a>
    <a class="button button-secondary" href={secondaryCtaHref}>
      <IconBook />
      {secondaryCtaLabel}
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-lg);
    background: linear-gradient(130deg, rgba(23, 26, 33, 0.94), rgba(31, 36, 48, 0.86));
    padding: clamp(1.6rem, 5vw, 3.4rem);
    display: grid;
    gap: 0.95rem;
    animation: fade-in 0.55s ease both;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: -30% -10% auto auto;
    width: 260px;
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(0, 209, 178, 0.35), transparent 60%);
    pointer-events: none;
  }

  .hero-kicker {
    color: var(--accent-primary);
    font-size: 0.78rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(1.9rem, 4vw, 3.4rem);
    line-height: 1.05;
  }

  .summary {
    color: var(--text-secondary);
    max-width: 760px;
    font-size: clamp(1rem, 2vw, 1.1rem);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.4rem;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
