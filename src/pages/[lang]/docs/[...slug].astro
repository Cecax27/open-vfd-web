---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../../../components/docs/DocsLayout.astro';
import { getDictionary, isLocale, locales, type Locale } from '../../../locales';

type DocEntry = CollectionEntry<'docs'>;

const docs = await getCollection('docs');
const orderedDocs = docs.sort((a, b) => a.data.order - b.data.order);

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return locales.flatMap((lang) =>
    docs.map((doc) => ({
      params: { lang, slug: doc.id },
      props: { doc, lang }
    }))
  );
}

const { doc, lang } = Astro.props as { doc: DocEntry; lang: string };

if (!isLocale(lang)) {
  return Astro.redirect('/en/docs');
}

const locale: Locale = lang;
const dictionary = getDictionary(locale);
const translatedArticle = dictionary.docs.articleTranslations[doc.id];
const articleTitle = translatedArticle?.title || doc.data.title;
const articleDescription = translatedArticle?.description || doc.data.description;
const articleTitles = Object.fromEntries(
  Object.entries(dictionary.docs.articleTranslations).map(([id, translation]) => [id, translation.title])
);
const { Content } = await render(doc);
---

<DocsLayout
  title={`${articleTitle} | OpenVFD Docs`}
  description={articleDescription}
  docs={orderedDocs}
  currentId={doc.id}
  locale={locale}
  sidebarTitle={dictionary.docs.sidebarTitle}
  categoryLabels={dictionary.docs.categories}
  articleTitles={articleTitles}
>
  <article class="prose">
    <header>
      <p class="mono muted">{dictionary.docs.categories[doc.data.category]}</p>
      <h1>{articleTitle}</h1>
      <p>{articleDescription}</p>
    </header>
    <Content />
  </article>
</DocsLayout>

<style>
  .prose {
    display: grid;
    gap: 1rem;
  }

  header {
    display: grid;
    gap: 0.4rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border-soft);
  }

  h1 {
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    line-height: 1.1;
  }

  p {
    color: var(--text-secondary);
  }

  :global(.prose h2),
  :global(.prose h3) {
    margin-top: 1rem;
  }

  :global(.prose p),
  :global(.prose li) {
    color: var(--text-secondary);
  }

  :global(.prose ul) {
    padding-left: 1.2rem;
    display: grid;
    gap: 0.3rem;
  }

  :global(.prose code) {
    background: rgba(58, 134, 255, 0.18);
    border-radius: 6px;
    padding: 0.08rem 0.35rem;
  }
</style>
