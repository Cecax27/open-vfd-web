---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import DocsLayout from '../../components/docs/DocsLayout.astro';

type DocEntry = CollectionEntry<'docs'>;

const docs = await getCollection('docs');
const orderedDocs = docs.sort((a, b) => a.data.order - b.data.order);

export async function getStaticPaths() {
  const docs = await getCollection('docs');

  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc }
  }));
}

const { doc } = Astro.props as { doc: DocEntry };
const { Content } = await render(doc);
---

<DocsLayout title={`${doc.data.title} | OpenVFD Docs`} description={doc.data.description} docs={orderedDocs} currentId={doc.id}>
  <article class="prose">
    <header>
      <p class="mono muted">{doc.data.category}</p>
      <h1>{doc.data.title}</h1>
      <p>{doc.data.description}</p>
    </header>
    <Content />
  </article>
</DocsLayout>

<style>
  .prose {
    display: grid;
    gap: 1rem;
  }

  header {
    display: grid;
    gap: 0.4rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border-soft);
  }

  h1 {
    font-size: clamp(1.5rem, 2.8vw, 2rem);
    line-height: 1.1;
  }

  p {
    color: var(--text-secondary);
  }

  :global(.prose h2),
  :global(.prose h3) {
    margin-top: 1rem;
  }

  :global(.prose p),
  :global(.prose li) {
    color: var(--text-secondary);
  }

  :global(.prose ul) {
    padding-left: 1.2rem;
    display: grid;
    gap: 0.3rem;
  }

  :global(.prose code) {
    background: rgba(58, 134, 255, 0.18);
    border-radius: 6px;
    padding: 0.08rem 0.35rem;
  }
</style>
