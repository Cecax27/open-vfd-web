---
import { getCollection } from 'astro:content';
import DocsLayout from '../../components/docs/DocsLayout.astro';
import DocsCategoryCard from '../../components/docs/DocsCategoryCard.astro';

const docs = await getCollection('docs');
const orderedDocs = docs.sort((a, b) => a.data.order - b.data.order);

const categories = [
  {
    key: 'getting-started',
    title: 'Getting Started',
    description: 'Project scope, installation instructions, and quick setup steps.',
    href: '/docs/getting-started/01-introduction'
  },
  {
    key: 'simulation',
    title: 'Simulation',
    description: 'Motor model, load behavior, and VFD parameter configuration.',
    href: '/docs/simulation/01-motor-model'
  },
  {
    key: 'opc-ua',
    title: 'OPC UA',
    description: 'Control variables and telemetry node strategy.',
    href: '/docs/opc-ua/01-overview'
  },
  {
    key: 'reference',
    title: 'Reference',
    description: 'Parameter list and implementation notes.',
    href: '/docs/reference/01-parameter-list'
  }
];
---

<DocsLayout title="Documentation | OpenVFD" description="OpenVFD guides and references" docs={orderedDocs}>
  <section class="doc-home">
    <h1>Documentation</h1>
    <p class="intro">
      Browse the OpenVFD documentation by category. Each guide focuses on one topic to keep setup and troubleshooting clear.
    </p>

    <div class="categories">
      {categories.map((category) => (
        <DocsCategoryCard
          href={category.href}
          title={category.title}
          description={category.description}
          total={orderedDocs.filter((entry) => entry.data.category === category.key).length}
        />
      ))}
    </div>

    <section class="all-entries">
      <h2>All Documentation Articles</h2>
      <ul>
        {orderedDocs.map((doc) => (
          <li>
            <a href={`/docs/${doc.id}`}>{doc.data.title}</a>
            <p>{doc.data.description}</p>
          </li>
        ))}
      </ul>
    </section>
  </section>
</DocsLayout>

<style>
  .doc-home {
    display: grid;
    gap: 1.3rem;
  }

  h1 {
    font-size: clamp(1.7rem, 3vw, 2.3rem);
  }

  .intro {
    color: var(--text-secondary);
    max-width: 720px;
  }

  .categories {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .all-entries {
    display: grid;
    gap: 0.65rem;
  }

  h2 {
    font-size: 1.25rem;
  }

  ul {
    list-style: none;
    display: grid;
    gap: 0.65rem;
  }

  li {
    padding: 0.8rem;
    border-radius: 12px;
    border: 1px solid var(--border-soft);
    background: rgba(31, 36, 48, 0.4);
  }

  li a {
    color: var(--text-primary);
    font-weight: 600;
  }

  li p {
    margin-top: 0.22rem;
    color: var(--text-muted);
    font-size: 0.92rem;
  }

  @media (max-width: 740px) {
    .categories {
      grid-template-columns: 1fr;
    }
  }
</style>
